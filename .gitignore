# .gitignore

# -----------------------------------------------------------------------------
# Python - Bytecode, Cache, and Distribution
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
*.whl

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.env
.venv
env/
venv/
ENV/
VENV/
pip-freeze.txt
pip-selfcheck.json

# -----------------------------------------------------------------------------
# IDE and Editor specific files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
# Operating System specific files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Project Specific Files
# -----------------------------------------------------------------------------
# 초기 개발에 사용된 Jupyter Notebook 파일
*.ipynb

# 테스트에 사용되는 PDF 파일이나 결과물 PDF 파일은 저장소에 올리지 않음
# 예시: watermark_full.pdf, watermark_full_removed.pdf 등
# 모든 PDF 파일을 무시하려면 아래 줄의 주석을 해제하세요.
# *.pdf

# 디버깅용으로 생성된 텍스트 덤프 파일
*_dump.txt

